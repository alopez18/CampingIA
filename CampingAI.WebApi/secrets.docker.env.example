# Plantilla de secretos para levantar el contenedor con docker compose por línea de comandos.
# Copia este archivo como "secrets.docker.env" (mismo directorio) y rellena los valores reales.
# El archivo real (*.docker.env) está ignorado por Git y NO debe subirse al repositorio.
#
# Nota: al depurar desde Visual Studio (perfil "Container (Dockerfile)") NO necesitas este
# archivo, porque VS monta automáticamente tus user-secrets dentro del contenedor.

Jwt__Key=REPLACE_WITH_JWT_SIGNING_KEY_MIN_32_CHARS
GoogleAuth__ClientId=REPLACE_WITH_GOOGLE_CLIENT_ID
GoogleAuth__ClientSecret=REPLACE_WITH_GOOGLE_CLIENT_SECRET
AISettings__ApiKey=REPLACE_WITH_GEMINI_API_KEY

# Si quieres apuntar a una BD externa en lugar de la del compose, descomenta y ajusta:
# ConnectionStrings__CAMPING_AI_SqlServer=Data Source=REPLACE_SERVER;Initial Catalog=REPLACE_DB;User ID=REPLACE_USER;Password=REPLACE_PASSWORD;Encrypt=False;TrustServerCertificate=True;Command Timeout=30
