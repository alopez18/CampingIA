@model CampingAI.WebApi.Controllers.Backoffice.DTO.CampingFormRequest
@{
    var isNew = Model.Id is null || Model.Id == System.Guid.Empty;
    ViewData["Title"] = isNew ? "Nuevo camping (Admin)" : "Editar camping (Admin)";
    var allCategories = ViewBag.Categories as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var allFacilities = ViewBag.Facilities as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">@ViewData["Title"]</h1>
            <a asp-action="Campings" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-arrow-left"></i> Volver
            </a>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <form asp-action="SaveCamping" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nombre</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Descripción</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Latitude" class="form-label">Latitud</label>
                    <input asp-for="Latitude" class="form-control" type="number" step="any" />
                    <span asp-validation-for="Latitude" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Longitude" class="form-label">Longitud</label>
                    <input asp-for="Longitude" class="form-control" type="number" step="any" />
                    <span asp-validation-for="Longitude" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="PricePerNight" class="form-label">Precio por noche</label>
                    <input asp-for="PricePerNight" class="form-control" type="number" step="any" />
                    <span asp-validation-for="PricePerNight" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CategoryId" class="form-label">Categoría principal</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                        <option value="">-- Selecciona una categoría --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Categorías secundarias</label>
                <div class="border rounded p-3" style="max-height:160px;overflow-y:auto;">
                    @foreach (var cat in allCategories) {
                        var catId = Guid.Parse(cat.Value);
                        var isChecked = Model.AdditionalCategoryIds.Contains(catId);
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="AdditionalCategoryIds"
                                   value="@cat.Value" id="addCat_@cat.Value"
                                   @(isChecked ? "checked" : "") />
                            <label class="form-check-label" for="addCat_@cat.Value">@cat.Text</label>
                        </div>
                    }
                </div>
                <div class="form-text">Se excluirá automáticamente la categoría principal si se selecciona aquí.</div>
            </div>
            <div class="mb-3">
                <label asp-for="ProvinciaId" class="form-label">Provincia</label>
                <select asp-for="ProvinciaId" asp-items="ViewBag.Provinces" class="form-select">
                    <option value="">-- Selecciona una provincia --</option>
                </select>
                <span asp-validation-for="ProvinciaId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Instalaciones (facilities)</label>
                <div class="border rounded p-3" style="max-height:200px;overflow-y:auto;">
                    @if (!allFacilities.Any()) {
                        <span class="text-muted small">No hay instalaciones disponibles.</span>
                    }
                    @foreach (var fac in allFacilities) {
                        var facId = Guid.Parse(fac.Value);
                        var isChecked = Model.FacilityIds.Contains(facId);
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="FacilityIds"
                                   value="@fac.Value" id="fac_@fac.Value"
                                   @(isChecked ? "checked" : "") />
                            <label class="form-check-label" for="fac_@fac.Value">@fac.Text</label>
                        </div>
                    }
                </div>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk"></i> Guardar
            </button>
            <a asp-action="Campings" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
