@{
    ViewData["Title"] = "Acceso al Backoffice";
    string? returnUrl = ViewBag.ReturnUrl as string;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 mt-5">
            <div class="card-body p-5 text-center">

                <div class="mb-4">
                    <i class="fa-solid fa-store fa-3x text-primary"></i>
                </div>

                <h1 class="h3 mb-3">¿Quieres gestionar campings?</h1>

                <p class="text-muted mb-4">
                    Para acceder al backoffice necesitas el rol de <strong>Gestor</strong>.
                    Puedes solicitar este rol ahora y un administrador lo revisará.
                    Una vez aprobado, podrás crear y gestionar tus propios campings.
                </p>

                <form asp-action="ConfirmBecomeGestor" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-lg px-4">
                        <i class="fa-solid fa-paper-plane"></i> Sí, solicitar acceso
                    </button>
                </form>

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 ms-2">
                    <i class="fa-solid fa-house"></i> No, volver al inicio
                </a>

            </div>
        </div>
    </div>
</div>
