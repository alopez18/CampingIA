@model IEnumerable<CampingAI.Domain.Entities.Camping>
@{
    ViewData["Title"] = "Mis campings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Mis campings</h1>
    <a asp-action="Create" class="btn btn-primary">Nuevo camping</a>
</div>

@if (!Model.Any()) {
    <div class="alert alert-info">Aún no has creado ningún camping.</div>
} else {
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Precio/noche</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var camping in Model) {
                <tr>
                    <td>@camping.Name.ToString()</td>
                    <td>@camping.PricePerNight.ToString()</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@camping.Id" class="btn btn-outline-secondary btn-sm">Editar</a>
                        <form asp-action="Delete" asp-route-id="@camping.Id" method="post" class="d-inline"
                              onsubmit="return confirm('¿Seguro que quieres borrar este camping?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Borrar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
